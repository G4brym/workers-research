{
	"$schema": "https://biomejs.dev/schemas/2.3.12/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": false
	},
	"files": {
		"ignoreUnknown": false,
		"includes": [
			"**",
			"!**/dist/**/*",
			"!**/src/forms/templates/**/*",
			"!**/src/forms/precompiled.mjs",
			"!**/src/static/styles.css"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noAssignInExpressions": "off",
				"noExplicitAny": "off",
				"noImplicitAnyLet": "off",
				"noArrayIndexKey": "off"
			},
			"style": {
				"noUnusedTemplateLiteral": "off",
				"useTemplate": "off",
				"useSelfClosingElements": "off",
				"noUselessElse": "off"
			},
			"complexity": {
				"noStaticOnlyClass": "off",
				"noBannedTypes": "off",
				"noForEach": "off",
				"noImportantStyles": "off"
			},
			"a11y": {
				"useButtonType": "off",
				"noSvgWithoutTitle": "off",
				"useSemanticElements": "off",
				"noLabelWithoutControl": "off",
				"useAltText": "off"
			},
			"correctness": {
				"useJsxKeyInIterable": "off",
				"noUnknownProperty": "off"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"overrides": [
		{
			"includes": ["**/src/static/*.js"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedFunctionParameters": "off"
					}
				}
			}
		}
	]
}
